generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id            String        @id @default(uuid())
  profile_image String?
  full_name     String
  email         String        @unique
  phone         String        @unique
  password      String
  channel_count Int           @default(0)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  channels      channels[]
  subscribers   subscribers[]
  likes         likes[]
  comments      comments[]
}

model channels {
  id                  String        @id @default(uuid())
  user_id             String
  user_ch             users         @relation(fields: [user_id], references: [id])
  profile_image       String?
  banner_image        String?
  channel_name        String
  channel_description String
  subscribers_count   BigInt        @default(0)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
  subscribers         subscribers[]
  videos              videos[]
}

model subscribers {
  user_id    String
  user_su    users    @relation(fields: [user_id], references: [id])
  channel_id String
  channel_su channels @relation(fields: [channel_id], references: [id])

  @@unique([user_id, channel_id])
}

model videos {
  id             String     @id @default(uuid())
  channel_id     String
  channel_vi     channels   @relation(fields: [channel_id], references: [id])
  video_url      String
  thumbnail_url  String
  title          String
  description    String
  likes_count    BigInt
  dislikes_count BigInt
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt
  likes          likes[]
  comments       comments[]
}

model likes {
  user_id    String
  user_like  users  @relation(fields: [user_id], references: [id])
  video_id   String
  video_like videos @relation(fields: [video_id], references: [id])

  @@unique([user_id, video_id])
}

model comments {
  id              String   @id @default(uuid())
  user_id         String
  user_comment    users    @relation(fields: [user_id], references: [id])
  video_id        String
  video_comment   videos   @relation(fields: [video_id], references: [id])
  comment_message String
  like_count      BigInt
  dislike_count   BigInt
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}
